        if player > 100 or player < 1 :
            print("The number is out of my scope")
        else :
         if player != computer_choise :
            attempts += 1
            print("Wrong Guess Try Again")
            print("My choise is " , computer_choise)
            print(attempts)
       
            print("Wrong Guess Try Again")
         else :
            print("Attempt taken ")
            print(attempts - 1)
            print("Your Guess is Right Congrates")
            break 
        

game = guess_number()
